local RS          = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players     = game:GetService("Players")
local Replion     = require(RS.Packages.Replion)

-- ===== SETTING — GANTI INI =====
local LOCAL_TEST  = false -- Set 'true' untuk tes di localhost, 'false' untuk domain asli
local API_KEY     = "ft__aoc8CxomU7YoWfhffpNnUeSbQ05FGh1QoysXAAgorc"
local INTERVAL    = 30

local SERVER_URL  = LOCAL_TEST and "http://localhost:8080/api/report" or "https://siganteng.store/api/report"
-- ================================

local DataReplion = Replion.Client:WaitReplion("Data")
local LP          = Players.LocalPlayer
local HWID        = tostring((gethwid or function() return "unknown" end)()):sub(1, 16)

local function getInventory()
    local ItemUtility = require(RS.Shared.ItemUtility)
    local evo = 0
    local secretTotal = 0
    local rubyGem = 0
    local secretFish = {}

    for _, item in ipairs(DataReplion:Get({"Inventory", "Items"}) or {}) do
        local ok, data = pcall(function() return ItemUtility:GetItemData(item.Id) end)
        if ok and data and data.Data then
            local name      = tostring(data.Data.Name)
            local qty       = item.Quantity or 1
            local itemType  = tostring(data.Data.Type or "")
            local itemTier  = data.Data.Tier
            local variantId = tostring((item.Metadata and item.Metadata.VariantId) or "")
            local matched   = false

            if itemType == "Fish" and (itemTier == 7 or name == "King Crab") then
                local key = name .. "|" .. variantId
                if not secretFish[key] then
                    secretFish[key] = { name = name, qty = 0, variant = variantId }
                end
                secretFish[key].qty += qty
                matched = true
            elseif itemTier == 5 and name == "Ruby" and variantId == "Gemstone" then
                rubyGem += qty
                matched = true
            elseif name == "Evolved Enchant Stone" then
                evo += qty
                matched = true
            end

            if not matched then
                secretTotal += qty
            end
        end
    end

    local secretList = {}
    local secretCount = 0  -- ← tambah ini
    for _, info in pairs(secretFish) do
        table.insert(secretList, { name = info.name, qty = info.qty, variant = info.variant })
        secretCount += info.qty  -- ← hitung total qty tier 7 saja
    end
    table.sort(secretList, function(a, b) return a.qty > b.qty end)

return evo, secretList, rubyGem, secretCount
end

local function getStatistics()
    local ok, stats = pcall(function()
        return DataReplion:Get({"Statistics"}) or {}
    end)
    if not ok then return {} end
    return {
        fishCaught        = stats.FishCaught        or 0,
        monthlyFishCaught = stats.MonthlyFishCaught or 0,
        caughtSecrets     = stats.CaughtSecrets     or 0,
        rarestFish        = math.floor(stats.RarestFishCaught or 0),
        monthlyLevel      = stats.MonthlyLevel      or 0,
    }
end

local function postToServer(evo, secretList, rubyGem, secretTotal)
    local serverId = tostring(game.JobId):sub(1, 8)
    local stats    = getStatistics()
    local ok, result = pcall(function()
        return request({
            Url     = SERVER_URL,
            Method  = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["X-API-Key"]    = API_KEY,   -- ← TAMBAHAN
            },
            Body    = HttpService:JSONEncode({
                player      = LP.Name,
                hwid        = HWID,
                serverId    = serverId,
                evo         = evo,
                secrets     = secretList,
                ruby_gem    = rubyGem,
                secretTotal = secretTotal,
                stats       = (next(stats) ~= nil) and stats or nil,
            })
        })
    end)
    if ok and result and result.StatusCode == 200 then
        print(string.format("[Inv] ✅ Sent | EVO=%d | T7=%d | Ruby=%d", evo, #secretList, rubyGem))
    else
        warn("[Inv] ❌ Error:", tostring(result and result.StatusCode or result))
        warn("[Inv] Body:", tostring(result and result.Body or "No Body"))
    end
end

print(string.format("[FishTracker] Start | %s | Interval: %ds", LP.Name, INTERVAL))
postToServer(getInventory())
while true do
    task.wait(INTERVAL)
    postToServer(getInventory())
end
