-- ══════════════════════════════════════════════════════
--  UTILS
-- ══════════════════════════════════════════════════════

local function exec(cmd)
  local h = io.popen(cmd .. " 2>/dev/null")
  local r = h:read("*a"); h:close()
  return (r or ""):match("^%s*(.-)%s*$")  -- trim
end

local function sleep_ms(ms)
  os.execute(string.format("sleep %.3f", ms / 1000))
end

local function jitter(lo, hi)
  local pid  = tonumber(exec("sh -c 'echo $$'")) or 1
  local seed = (os.time() * 1000 + pid * 13 + math.floor((os.clock() * 1e5)) % 997)
  math.randomseed(seed % 2147483647)
  return math.random(lo, hi)
end

local function curl(url)
  return exec(string.format('curl -s --max-time 15 --retry 2 "%s"', url))
end

-- JSON mini-parser (tidak butuh library eksternal)
local function jstr(t, k)  return t:match('"'..k..'":%s*"([^"]*)"') end
local function jnum(t, k)  local v = t:match('"'..k..'":%s*(%d+)'); return v and tonumber(v) end
local function jbool(t, k)
  -- Cari pattern "key": true atau "key": false (dengan variasi whitespace)
  local v = t:match('"'..k..'":%s*(true)')
  if v then return true end
  v = t:match('"'..k..'":%s*(false)')
  if v then return false end
  -- Fallback: cek apakah key ada dengan nilai 1 atau 0
  v = t:match('"'..k..'":%s*([01])[^%d]')
  if v == "1" then return true end
  if v == "0" then return false end
  return nil
end

-- Cek response sukses: ok=true ATAU ada field "status"/"name" (claim berhasil)
local function is_ok(resp)
  if jbool(resp, "ok") == true then return true end
  -- Fallback: kalau ada "name" dan "link" di response, berarti berhasil
  if jstr(resp, "name") and jstr(resp, "status") then return true end
  return false
end

local function is_pool_empty(resp)
  return resp:find("Pool kosong") ~= nil
      or resp:find("pool") ~= nil
      or resp:find('"ok":false') ~= nil
      or resp:find('"ok": false') ~= nil
end

-- ══════════════════════════════════════════════════════
--  DEVICE ID — otomatis dari ro.serialno / MAC / boot_id
-- ══════════════════════════════════════════════════════

local function make_device_id()
  local function try(cmd)
    local v = exec(cmd)
    if v ~= "" and v ~= "unknown" and #v > 3 then return v end
  end

  -- 1. Serial number (primary, terbukti unik per cloud-phone instance)
  local s = try("getprop ro.serialno")
  if s then return "dev_" .. s:gsub("[^%w]",""):sub(1,20) end

  -- 2. MAC wlan0 (fallback)
  local m = try("ip link show wlan0 | awk '/ether/{print $2}'")
  if m and m ~= "ff:ff:ff:ff:ff:ff" and m ~= "00:00:00:00:00:00" then
    return "dev_" .. m:gsub(":",""):sub(1,12)
  end

  -- 3. boot_id (last resort, berubah tiap reboot)
  local b = try("cat /proc/sys/kernel/random/boot_id")
  if b then
    local h = 0
    for i=1,#b do h=(h*31+b:byte(i))%0xFFFFFFFF end
    return ("dev_boot%08x"):format(h)
  end

  -- 4. Random permanent fallback
  math.randomseed(os.time())
  return ("dev_rand%08x"):format(math.random(0,0xFFFFFFFF))
end

local function get_device_id()
  local f = io.open(DEVICE_ID_FILE, "r")
  if f then
    local id = f:read("*l"); f:close()
    if id and id:match("^dev_") then return id end
  end
  local id = make_device_id()
  local fw = io.open(DEVICE_ID_FILE, "w")
  if fw then fw:write(id.."\n"); fw:close() end
  return id
end

-- ══════════════════════════════════════════════════════
--  AUTO_REJOIN.CONF — baca & tulis preserving key order
-- ══════════════════════════════════════════════════════

local function read_conf()
  local map, order = {}, {}
  local f = io.open(CONF_PATH, "r")
  if not f then return map, order end
  for line in f:lines() do
    local k, v = line:match("^([^=#][^=]-)=(.*)$")
    if k then
      if not map[k] then table.insert(order, k) end
      map[k] = v
    end
  end
  f:close()
  return map, order
end

local function write_conf(map, order)
  local f = io.open(CONF_PATH, "w")
  if not f then return false end
  local done = {}
  for _, k in ipairs(order) do
    f:write(k.."="..(map[k] or "").."\n")
    done[k] = true
  end
  for k,v in pairs(map) do
    if not done[k] then f:write(k.."="..tostring(v).."\n") end
  end
  f:close()
  return true
end

