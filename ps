local function ensure_conf_exists()
  -- 1. Pastikan folder ada
  local folder = CONF_PATH:match("^(.*)/[^/]+$")
  if folder then
    local ok = os.execute('mkdir -p "' .. folder .. '" 2>/dev/null')
    if ok ~= 0 and ok ~= true then
      -- mkdir gagal (mungkin butuh permission storage)
      io.write("[!] Tidak bisa buat folder: "..folder.."\n")
      io.write("    Jalankan: termux-setup-storage\n")
      return false
    end
  end

  -- 2. Cek apakah file ada
  local f = io.open(CONF_PATH, "r")
  if f then f:close(); return true end

  -- 3. File belum ada → buat dengan template default
  io.write("[*] auto_rejoin.conf belum ada — membuat file baru...\n")
  local fw = io.open(CONF_PATH, "w")
  if not fw then
    io.write("[!] Gagal buat file conf. Cek permission storage.\n")
    io.write("    Jalankan: termux-setup-storage\n")
    return false
  end
  fw:write(CONF_DEFAULT)
  fw:close()
  io.write("[+] auto_rejoin.conf dibuat: "..CONF_PATH.."\n")
  return true
end

local function set_deeplink(link)
  -- Pastikan file & folder ada sebelum tulis
  if not ensure_conf_exists() then return false end

  local map, order = read_conf()
  -- Sisipkan 'deeplink' setelah 'enabled' kalau belum ada
  if not map["deeplink"] then
    local o2, inserted = {}, false
    for _, k in ipairs(order) do
      table.insert(o2, k)
      if k == "enabled" and not inserted then
        table.insert(o2, "deeplink")
        inserted = true
      end
    end
    if not inserted then table.insert(o2, 1, "deeplink") end
    order = o2
  end
  map["deeplink"] = link
  return write_conf(map, order)
end

-- ══════════════════════════════════════════════════════
--  STATE LOKAL — ingat link yang sudah di-claim
-- ══════════════════════════════════════════════════════

local function save_state(t)
  local f = io.open(STATE_FILE, "w")
  if not f then return end
  for k,v in pairs(t) do f:write(k.."="..tostring(v).."\n") end
  f:close()
end

local function load_state()
  local f = io.open(STATE_FILE, "r")
  if not f then return nil end
  local s = {}
  for line in f:lines() do
    local k,v = line:match("^([^=]+)=(.+)$")
    if k then s[k]=v end
  end
  f:close()
  return (s.best_link and s.best_link~="") and s or nil
end

-- ══════════════════════════════════════════════════════
--  MAIN — one-shot auto claim
-- ══════════════════════════════════════════════════════

local DEVICE = get_device_id()

io.write("\n")
io.write("┌─────────────────────────────────────┐\n")
io.write("│     Private Server Auto Claim        │\n")
io.write("└─────────────────────────────────────┘\n")
io.write("  Device  : "..DEVICE.."\n")
io.write("  Server  : "..SERVER_URL.."\n")
io.write("  Conf    : "..CONF_PATH.."\n\n")

-- Cek apakah device sudah punya link aktif (idempotent re-run)
local existing = load_state()
if existing then
  io.write("[~] Device sudah punya link aktif:\n")
  io.write("    Name     : "..(existing.name or "-").."\n")
  io.write("    Link     : "..(existing.best_link or "-").."\n")
  io.write("    Claimed  : "..(existing.claimed_at or "-").."\n\n")
  io.write("[*] Re-apply ke auto_rejoin.conf...\n")
  if set_deeplink(existing.best_link) then
    io.write("[+] auto_rejoin.conf ✓ OK (re-applied)\n")
  else
    io.write("[!] Gagal tulis conf. Manual:\n")
    io.write("    deeplink="..existing.best_link.."\n")
  end
  io.write("\n[+] SELESAI\n")
  os.exit(0)
end

-- Jitter awal: distribusikan request saat sync mode
-- Semua device start bersamaan → tiap device delay acak 0–3 detik
local jit = jitter(0, 3000)
if jit > 50 then
  io.write(string.format("[*] Jitter: %.1f detik (anti-collision sync mode)...\n", jit/1000))
  sleep_ms(jit)
end

-- Claim loop dengan retry + backoff
local url = SERVER_URL.."/claim?device="..DEVICE
local claimed = false

for attempt = 1, MAX_RETRIES do
  io.write(string.format("[*] Attempt %d/%d — claim...\n", attempt, MAX_RETRIES))

  local resp = curl(url)

  if resp == "" then
    io.write("[!] Tidak bisa konek ke server (timeout/down).\n")
    if attempt < MAX_RETRIES then
      local w = jitter(1000, 4000)
      io.write(string.format("[~] Retry dalam %.1f detik...\n", w/1000))
      sleep_ms(w)
    end

  elseif is_ok(resp) then
    -- Berhasil claim
    local name       = jstr(resp, "name")       or "-"
    local link       = jstr(resp, "link")       or ""
    local deeplink   = jstr(resp, "deeplink")   or ""
    local best_link  = jstr(resp, "best_link")  or deeplink or link
    local claimed_at = jstr(resp, "claimed_at") or "-"
    local status_v   = jstr(resp, "status")     or "claimed"
    local remaining  = jnum(resp, "pool_remaining")

    io.write("\n")
    io.write("  Status     : "..status_v.."\n")
    io.write("  Name       : "..name.."\n")
    if deeplink ~= "" then
      io.write("  Deeplink   : "..deeplink.."\n")
    else
      io.write("  Share Link : "..link.."\n")
    end
    io.write("  → Dipakai  : "..best_link.."\n")
    io.write("  Waktu      : "..claimed_at.."\n")
    if remaining then
      io.write("  Sisa pool  : "..remaining.."\n")
    end
    io.write("\n")

    -- Simpan state lokal
    save_state({
      device     = DEVICE,
      name       = name,
      link       = link,
      deeplink   = deeplink,
      best_link  = best_link,
      claimed_at = claimed_at
    })

    -- Tulis ke auto_rejoin.conf
    if best_link ~= "" then
      if set_deeplink(best_link) then
        io.write("[+] auto_rejoin.conf ✓ diupdate\n")
      else
        io.write("[!] Gagal tulis conf — salin manual:\n")
        io.write("    deeplink="..best_link.."\n")
      end
    else
      io.write("[!] Link kosong — conf tidak diubah.\n")
    end

    claimed = true
    break

  else
    -- Gagal: cek jenis error
    local err = jstr(resp, "error") or ""
    local is_empty = is_pool_empty(resp)

    if is_empty then
      -- Pool kosong = permanen, tidak ada gunanya retry
      io.write("\n")
      io.write("╔══════════════════════════════════════════╗\n")
      io.write("║  LINK HABIS — Device ini tidak kebagian  ║\n")
      io.write("╚══════════════════════════════════════════╝\n")
      io.write("\n")
      io.write("  Jumlah link di pool tidak cukup untuk semua device.\n")
      io.write("  Device ini tidak mendapat private server.\n")
      io.write("\n")
      io.write("  Solusi:\n")
      io.write("  1. Generate link baru dengan genps.py\n")
      io.write("  2. Upload hopper.json baru ke server\n")
      io.write("  3. Jalankan: curl SERVER_URL/import\n")
      io.write("  4. Run ps.lua lagi\n")
      io.write("\n")
      io.write("  Status pool: "..SERVER_URL.."/status\n")
      io.write("\n")
      os.exit(1)  -- exit code 1 = gagal, bisa dideteksi automation
    else
      io.write("[ERROR] "..(err ~= "" and err or resp).."\n")
      if attempt < MAX_RETRIES then
        local w = jitter(500, 2000)
        io.write(string.format("[~] Retry %d/%d dalam %.1f detik...\n",
                 attempt, MAX_RETRIES, w/1000))
        sleep_ms(w)
      end
    end
  end
end

io.write("\n")
if claimed then
  io.write("[+] SELESAI — WinterHub siap dijalankan.\n")
else
  -- Sampai sini berarti koneksi error berulang (bukan pool kosong)
  io.write("[!] GAGAL koneksi ke server setelah "..MAX_RETRIES.."x percobaan.\n")
  io.write("    Pastikan server berjalan: "..SERVER_URL.."\n")
end
io.write("\n")
